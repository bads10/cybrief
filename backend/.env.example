# Base de données PostgreSQL (Railway, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/cybrief"

# Fournisseur IA pour résumés/classification : "deepseek" (défaut) ou "gemini"
AI_PROVIDER="deepseek"

# DeepSeek API (résumés bilingues + filtre de pertinence des tweets)
DEEPSEEK_API_KEY="sk-your_deepseek_api_key"
# Optionnels (valeurs par défaut sensées) :
# DEEPSEEK_MODEL="deepseek-chat"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/chat/completions"

# Google Gemini API (fallback si AI_PROVIDER=gemini ou si DeepSeek indisponible)
GEMINI_API_KEY="your_gemini_api_key"

# Réglages ingestion (optionnels)
# AI_DELAY_MS=1200          # délai entre appels IA (ms) ; 5000 conseillé pour Gemini
# MAX_ITEMS_PER_FEED=3      # articles max traités par flux et par run

# Clé secrète pour le dashboard admin
ADMIN_KEY="your_secret_admin_key"

# Webhook RevenueCat (abonnements mobile)
REVENUECAT_WEBHOOK_SECRET="your_revenuecat_webhook_secret"

# Resend (newsletter + emails transactionnels)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="newsletter@cybrief.io"

# Firebase Admin SDK (notifications push FCM)
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Serveur
PORT=3000
NODE_ENV=development

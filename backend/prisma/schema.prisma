generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id              Int      @id @default(autoincrement())
  title           String
  summary         String
  criticality     String
  tags            String
  url             String   @unique
  status          String   @default("DRAFT")
  // Indicateurs techniques extraits par Gemini
  cve             String   @default("")
  attackType      String   @default("")
  affectedSystems String   @default("")
  iocs            String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Source {
  id        Int      @id @default(autoincrement())
  name      String
  url       String   @unique
  category  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
